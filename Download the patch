+import type { EnvelopeReport, RuntimeEnvelopeState, RuntimeWeights } from "./types"
+
+export function computeEnvelopeValue(
+  state: RuntimeEnvelopeState,
+  weights: Pick<RuntimeWeights, "C_phi" | "C_r">
+): number {
+  return state.e + weights.C_phi * state.phi + weights.C_r * state.r
+}
+
+export function deriveFacet(
+  state: RuntimeEnvelopeState,
+  weights: Pick<RuntimeWeights, "C_phi" | "C_r">
+): string {
+  const a = state.e + weights.C_phi * state.phi + weights.C_r * state.r
+  const phiDominant = state.phi >= state.r
+  if (phiDominant) return `Facet A (${a.toFixed(2)})`
+  return `Facet B (${a.toFixed(2)})`
+}
+
+export function evaluateEnvelope(
+  state: RuntimeEnvelopeState,
+  weights: RuntimeWeights
+): EnvelopeReport {
+  const value = computeEnvelopeValue(state, weights)
+  return {
+    value,
+    limit: weights.M_pred,
+    violated: value > weights.M_pred,
+    facet: deriveFacet(state, weights),
+  }
+}

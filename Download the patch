+}
+
+export default function FuturePanel({ feed }: Props) {
+  const [filter, setFilter] = useState<FilterKey>("ALL")
+
+  const filtered = useMemo(() => {
+    switch (filter) {
+      case "EXEC_ONLY":
+        return feed.filter((x) => x.signal.traceStatus === "EXEC")
+      case "CRITICAL_FAIL":
+        return feed.filter((x) => x.signal.traceStatus === "CRITICAL_FAIL")
+      case "ENVELOPE_EDGE":

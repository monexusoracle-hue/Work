+import type {
+  DecisionCertification,
+  DecisionClass,
+  InvariantReport,
+  PatternInsight,
+  RuntimeEnvelopeState,
+  RuntimeWeights,
+  SourceTier,
+} from "./types"
+import { evaluateEnvelope } from "./envelope"
+
+export function deriveConfidence(args: {
+  patternSimilarity?: number
+  invariantPassed: boolean
+  signalIntegrityScore: number
+}): number {
+  const pattern = Math.max(0, Math.min(1, args.patternSimilarity ?? 0))
+  const invariant = args.invariantPassed ? 1 : 0
+  const signal = Math.max(0, Math.min(1, args.signalIntegrityScore))
+  const raw = 0.4 * pattern + 0.3 * invariant + 0.3 * signal
+  return Number(raw.toFixed(3))
+}
+
+export function buildReasoning(args: {
+  decision: DecisionClass
+  score: number
+  invariants: InvariantReport
+  envelopeViolated: boolean
+  pattern?: PatternInsight | null
+  sourceTier: SourceTier
+}): string[] {
+  const reasons: string[] = []
+  reasons.push(`Decision ${args.decision} from score ${args.score.toFixed(2)}`)
+  reasons.push(args.invariants.passed ? "MFCS invariants passed" : "MFCS invariants failed")
+  reasons.push(args.envelopeViolated ? "Envelope violated" : "Envelope safe")
+  reasons.push(`Source tier: ${args.sourceTier}`)
+  if (args.pattern) {
+    reasons.push(
+      `Pattern match ${args.pattern.label} (${(args.pattern.similarity * 100).toFixed(1)}%)`
+    )
+  }
+  return reasons
+}
+
+export function certifyDecision(args: {
+  decision: DecisionClass
+  score: number
+  invariants: InvariantReport
+  state: RuntimeEnvelopeState
+  weights: RuntimeWeights
+  pattern?: PatternInsight | null
+  sourceTier: SourceTier
+  signalIntegrityScore: number
+}): DecisionCertification {
+  const envelope = evaluateEnvelope(args.state, args.weights)
+  const confidence = deriveConfidence({
+    patternSimilarity: args.pattern?.similarity,
+    invariantPassed: args.invariants.passed,
+    signalIntegrityScore: args.signalIntegrityScore,
+  })
+
+  const rejected = !args.invariants.passed || envelope.violated
+
+  return {
+    status: rejected ? "REJECTED" : "CERTIFIED",
+    decision: rejected ? "ABORT" : args.decision,
+    score: args.score,
+    confidence,
+    reasoning: buildReasoning({
+      decision: rejected ? "ABORT" : args.decision,
+      score: args.score,
+      invariants: args.invariants,
+      envelopeViolated: envelope.violated,
+      pattern: args.pattern,
+      sourceTier: args.sourceTier,
+    }),
+    envelope,
+    invariants: args.invariants,
+    pattern: args.pattern ?? null,
+    sourceTier: args.sourceTier,
+  }
+}
+

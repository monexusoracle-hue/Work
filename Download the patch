+import type { InvariantReport } from "../types"
+
 export type State = "IDLE" | "EVAL" | "EXEC";
 
+export interface DecisionOption {
+  id: string;
+  payload: any;
+}
+
+export interface DecisionResult {
+  chosen: DecisionOption | null;
+  trace: State[];
+  invariantReport: InvariantReport;
+}
+
 // Existing kernel code assumed here.
@@ -5,3 +21,50 @@
+function buildInvariantReport(violations: string[]): InvariantReport {
+  return {
+    passed: violations.length === 0,
+    status: violations.length === 0 ? "PASS" : "FAIL",
+    violations,
+  }
+}
+
+export function decide(v: any, ctx: any, options: DecisionOption[]): DecisionResult {
+  const violations: string[] = []
+
+  const anchored = anchor(v, ctx)
+  const evald = evaluate(anchored, options)
+  const expanded = expand(anchored, evald)
+  const chosen = harmonize(anchored, expanded)
+
+  const h1: State[] = [...(anchored.history ?? []), "EVAL"]
+  const h2: State[] = chosen ? [...h1, "EXEC", "IDLE"] : [...h1, "IDLE"]
+
+  if (!anchored.invariants.T1_order(h2)) violations.push("T1_ORDER_VIOLATION")
+  if (!anchored.invariants.T3_continuity(h2)) violations.push("T3_CONTINUITY_VIOLATION")
+  if (!anchored.invariants.M1_stability(anchored.context)) violations.push("M1_STABILITY_VIOLATION")
+  if (!anchored.invariants.M2_coherence(anchored.context)) violations.push("M2_COHERENCE_VIOLATION")
+
+  return {
+    chosen,
+    trace: h2,
+    invariantReport: buildInvariantReport(violations),
+  }
+}

+          const { value, limit } = x.certification.envelope
+          return value / Math.max(limit, 0.0001) >= 0.85
+        })
+      case "HIGH_PATTERN":
+        return feed.filter((x) => (x.certification.pattern?.similarity ?? 0) >= 0.8)
+      case "LOW_CONFIDENCE":
+        return feed.filter((x) => x.certification.confidence < 0.5)
+      default:
+        return feed
+    }
+  }, [feed, filter])
+
+  const counts: Record<FilterKey, number> = {
+    ALL: feed.length,
+    EXEC_ONLY: feed.filter((x) => x.signal.traceStatus === "EXEC").length,
+    CRITICAL_FAIL: feed.filter((x) => x.signal.traceStatus === "CRITICAL_FAIL").length,

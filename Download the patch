+export function computeScore(signal: StrategicSignal): number {
+  return (
+    100 * signal.momentum * signal.confidence * signal.reputation -
+    50 * signal.volatility
+  )
+}
+
+export function classifyDecision(score: number, riskTolerance = 0.5): DecisionClass {
+  if (score < -40) return "DEFEND"
+  if (score > 40 && riskTolerance > 0.5) return "EXPLOIT"
+  if (score > 5) return "HOLD"
+  return "IGNORE"
+}
+
+export function deriveRuntimeState(signal: StrategicSignal, score: number): RuntimeEnvelopeState {
+  // Replace with your true runtime projection if already present.
+  const phi = Math.max(0, Math.round(signal.marketImpact / 10))
+  const r = Math.max(0, Math.round(signal.securityRisk / 10))
+  const e = Math.max(0, Math.round(score / 20))
+  return { e, phi, r, integ: phi + r }
+}
+
+export function deriveContext(signal: StrategicSignal, score: number) {
+  return {
+    score,
+    sourceTier: signal.sourceTier,
+    operator_energy: "steady",
+    time_available_min: 45,
+    signalIntegrity:
+      signal.sourceTier === "LIVE_API"
+        ? "STABLE"
+        : signal.sourceTier === "CACHE"
+          ? "DEGRADED"
+          : "INTERFERENCE",
+  }
+}
+
+export function deriveOptions(signal: StrategicSignal, score: number) {
+  return [
+    { id: "DEFEND", payload: { allowed: signal.securityRisk > 60 || score < -40 } },
+    { id: "EXPLOIT", payload: { allowed: score > 40 } },
+    { id: "HOLD", payload: { allowed: true } },
+    { id: "IGNORE", payload: { allowed: score < 5 } },
+  ]
+}
+
+export function derivePattern(signal: StrategicSignal): PatternInsight | null {
+  // Replace with your real memory engine output if already present.
+  const similarity = Math.min(0.95, Math.max(0.12, signal.confidence * 0.9))
+  return {
+    label: similarity > 0.8 ? "Supply Shock 2023" : "Generic Market Drift",
+    similarity,
+    expectedOutcome: similarity > 0.8 ? "Defensive posture historically outperformed" : "Mixed outcome",
+    confidenceBoost: similarity > 0.8 ? 8 : 0,
+  }
+}
+
+export function processSignal(
+  signal: StrategicSignal,
+  config: EngineConfig,
+  vessel: any
+): OperatorFeedItem {
+  const baseScore = computeScore(signal)
+  const pattern = derivePattern(signal)
+  const score = baseScore + (pattern?.confidenceBoost ?? 0)
+  const decision = classifyDecision(score, config.riskTolerance)
+  const state = deriveRuntimeState(signal, score)
+  const context = deriveContext(signal, score)
+  const options = deriveOptions(signal, score)
+
+  const kernelResult = decide(vessel, context, options)
+
+  const certification = certifyDecision({
+    decision,
+    score,
+    invariants: kernelResult.invariantReport ?? {
+      passed: true,
+      status: "PASS",
+      violations: [],
+    },
+    state,
+    weights: {
+      C_phi: config.C_phi,
+      C_r: config.C_r,
+      M_pred: config.M_pred,
+    },
+    pattern,
+    sourceTier: signal.sourceTier,
+    signalIntegrityScore:
+      signal.sourceTier === "LIVE_API"
+        ? 1
+        : signal.sourceTier === "CACHE"
+          ? 0.66
+          : 0.33,
+  })
+
+  return {
+    id: signal.id,
+    signal: {
+      ...signal,
+      traceStatus: certification.status === "REJECTED"
+        ? "CRITICAL_FAIL"
+        : kernelResult.trace?.includes("EXEC")
+          ? "EXEC"
+          : "IDLE",
+    },
+    state,
+    certification,
+    mfcs: {
+      vesselState: kernelResult.trace?.[kernelResult.trace.length - 1] ?? "IDLE",
+      trace: kernelResult.trace ?? ["IDLE"],
+      invariantReport: kernelResult.invariantReport ?? {
+        passed: true,
+        status: "PASS",
+        violations: [],
+      },
+    },
+    contextSnapshot: context,
+  }
+}
+

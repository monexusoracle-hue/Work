diff --git a/mfcs-omega/src/lib/oracleKernelCore.test.ts b/mfcs-omega/src/lib/oracleKernelCore.test.ts
index 3333333..4444444 100644
--- a/mfcs-omega/src/lib/oracleKernelCore.test.ts
+++ b/mfcs-omega/src/lib/oracleKernelCore.test.ts
@@ -10,6 +10,10 @@ const facetA = core.evaluate({
 assert.equal(facetA.inPhiAttractor, true);
 assert.equal(facetA.attractorId, 'G_phi');
+assert.equal(facetA.lawCompliance?.lawId, 'phi-A');
+assert.equal(facetA.lawCompliance?.irreversible, true);
+assert.equal(facetA.lawCompliance?.nearRecursion, false);
+assert.equal(facetA.lawCompliance?.inAttractor, true);
 
@@ -24,6 +28,30 @@ const facetB = core.evaluate({
 assert.equal(facetB.inPhiAttractor, false);
 assert.equal(facetB.attractorId, undefined);
+assert.equal(facetB.lawCompliance?.lawId, 'phi-A');
+assert.equal(facetB.lawCompliance?.irreversible, false);
+assert.equal(facetB.lawCompliance?.nearRecursion, false);
+assert.equal(facetB.lawCompliance?.inAttractor, false);
+
+const facetC = core.evaluate({
+  W: 1,
+  inside: true,
+  margin: 0.1,
+  gap: 0,
+  kink: null,
+  weights: { C_r: 1 },
+  classification: { facet: 'Facet-C', label: 'C', M_min: 2 },
+  state: { mode: 'BUILD_COMPRESS' },
+});
+assert.equal(facetC.inPhiAttractor, true);
+assert.equal(facetC.attractorId, 'G_phi');
+assert.equal(facetC.lawCompliance?.irreversible, true);
+assert.equal(facetC.lawCompliance?.nearRecursion, false);
+assert.equal(facetC.lawCompliance?.inAttractor, true);
+
+const phiOutside = core.evaluate({
+  W: 1,
+  inside: false,
+  margin: 0.1,
+  gap: 0,
+  kink: null,
+  weights: { C_r: 1 },
+  classification: { facet: 'Facet-C', label: 'C', M_min: 2 },
+  state: { mode: 'BUILD_COMPRESS' },
+});
+assert.equal(phiOutside.inPhiAttractor, false);
+assert.equal(phiOutside.attractorId, undefined);
+assert.equal(phiOutside.lawCompliance?.irreversible, true);
+assert.equal(phiOutside.lawCompliance?.nearRecursion, false);
+assert.equal(phiOutside.lawCompliance?.inAttractor, false);
+
+const fusion = core.evaluate({
+  W: 1,
+  inside: true,
+  margin: 0.1,
+  gap: 0,
+  kink: null,
+  weights: { C_r: 1 },
+  classification: { facet: 'Facet-A', label: 'A', M_min: 2 },
+  state: { mode: 'FUSION' },
+});
+assert.equal(fusion.inPhiAttractor, true);
+assert.equal(fusion.attractorId, 'G_phi');
+assert.equal(fusion.lawCompliance?.irreversible, true);
+assert.equal(fusion.lawCompliance?.nearRecursion, false);
+assert.equal(fusion.lawCompliance?.inAttractor, true);
